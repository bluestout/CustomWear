        "collapsible_row_YJXA64": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Shipping Information",
            "icon": "none",
            "row_content": "<p>Domestic Shipping (U.S.):<br/>Once shipped most orders are typically delivered within 5–7 business days after shipping.<br/>Shipped via UPS or FedEx Ground.<br/>You will be notified within 24 hours Monday to Friday if an item is out of stock.<br/>Customers may use their FedEx or UPS accounts if the billing name matches the account name with the carrier.<br/><br/>International Shipping:<br/>International orders may be available. Please email info@customizedwear.com with the subject line \"International Order\" and include your specific request and destination address.<br/>Customs delays, duties, and import taxes are the responsibility of the recipient.<br/>Most international shipments are sent via USPS Air Parcel Post or International Priority Mail (4–12 business days).<br/>For Canadian orders, we use USPS, UPS, or FedEx Ground. If a preferred customs broker is required, specify before shipment. Broker changes cannot be made once an order has shipped out.</p>",
            "page": ""
          }
        },
        "collapsible_row_JD7UxP": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Shipping Policies",
            "icon": "none",
            "row_content": "<p>Standard UPS or FedEx Ground is our primary shipping method.<br/>Shipping rates may vary if items are shipped from multiple locations. You will be notified of any cost adjustments.<br/>Express or Air Shipping will receive a custom freight quote, pending approval.<br/>International orders will receive a custom freight quote. We are not responsible for customs and duty fees.</p>",
            "page": ""
          }
        },
        "collapsible_row_BFtyRk": {

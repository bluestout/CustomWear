{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- style -%}
  .ai-product-carousel-{{ ai_gen_id }} {
    display: block;
    position: relative;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    width: 100%;
  }

  {% if block.settings.border_bottom %}
    .ai-product-carousel-{{ ai_gen_id }}::after {
      border-bottom: 1px solid #C6C6C6;
      content: '';
      display: block;
      width: 100%;
      max-width: 700px;
      height: 0px;
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
    }
  {% endif %}

  .ai-product-carousel-{{ ai_gen_id }} .container {
    width: 100%;
  }

  .ai-product-carousel-{{ ai_gen_id }} .page-width {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ai-carousel-title-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 30px;
  }

  .ai-carousel-title-{{ ai_gen_id }} {
    text-align: center;
    margin: 0;
  }

  .ai-carousel-title-{{ ai_gen_id }} h2,
  .ai-carousel-title-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-carousel-navigation-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    gap: 10px;
  }

  .ai-carousel-nav-btn-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: transparent;
    border: 2px solid #000000;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .ai-carousel-nav-btn-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-carousel-nav-btn-{{ ai_gen_id }}.swiper-button-disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-nav-btn-{{ ai_gen_id }} svg {
    width: 12px;
    height: 12px;
    fill: #800000;
  }

  .ai-swiper-{{ ai_gen_id }} {
    overflow: visible;
  }

  .ai-swiper-{{ ai_gen_id }} .swiper-wrapper {
    display: flex;
  }

  .ai-swiper-{{ ai_gen_id }} .swiper-slide {
    height: auto;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    text-decoration: none;
    display: block;
    height: 100%;
  }

  .ai-product-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: 12px;
    {% if settings.card_style == 'card' %}
      background-color: rgba(var(--color-foreground), 0.04);
      padding: {{ settings.card_image_padding }}px;
      border-radius: {{ settings.card_corner_radius }}px;
    {% endif %}
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s ease;
  }

  .ai-product-card-image-secondary-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card-image-secondary-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-product-card-info-{{ ai_gen_id }} {
    text-align: {{ settings.card_text_alignment }};
  }

  .ai-product-card-vendor-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    margin-bottom: 4px;
    opacity: 0.7;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: 14px;
    margin-bottom: 8px;
    color: rgb(var(--color-foreground));
  }

  .ai-product-card-rating-{{ ai_gen_id }} {
    margin-bottom: 8px;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: rgb(var(--color-foreground));
  }

  .ai-product-card-price-{{ ai_gen_id }} .price--on-sale {
    color: rgb(var(--color-foreground));
  }

  .ai-product-card-price-{{ ai_gen_id }} .price__sale .price-item--regular {
    text-decoration: line-through;
    opacity: 0.7;
  }

  @media (max-width: 989px) {
    .ai-product-carousel-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ block.settings.padding_bottom | divided_by: 2 }}px;
    }

    .ai-carousel-navigation-{{ ai_gen_id }} {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .ai-product-carousel-{{ ai_gen_id }}::after {
      max-width: calc(100% - 3rem);
    }

    .ai-carousel-title-{{ ai_gen_id }} {
      text-align: center;
    }
  }

  @media (max-width: 749px) {
    .ai-carousel-title-wrapper-{{ ai_gen_id }} {
      margin-bottom: 20px;
    }
  }
{%- endstyle -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<div class="ai-product-carousel-{{ ai_gen_id }} color-{{ settings.card_color_scheme }}" {{ block.shopify_attributes }}>
  <div class="container">
    <div class="page-width">
      <div class="swiper">
        <div class="ai-carousel-title-wrapper-{{ ai_gen_id }}">
          {% if block.settings.title != blank %}
            <div class="ai-carousel-title-{{ ai_gen_id }}">
              {{ block.settings.title }}
            </div>
          {% endif %}
          <div class="ai-carousel-navigation-{{ ai_gen_id }} small-hide">
            <div class="swiper-button-prev ai-carousel-nav-btn-{{ ai_gen_id }} ai-swiper-button-prev-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
              </svg>
            </div>
            <div class="swiper-button-next ai-carousel-nav-btn-{{ ai_gen_id }} ai-swiper-button-next-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="ai-swiper-{{ ai_gen_id }}">
          <div class="swiper-wrapper">
            {% for product_block in block.settings.products %}
              {% assign product = product_block %}
              {% if product != blank %}
                <div class="swiper-slide">
                  <a href="{{ product.url }}" class="ai-product-card-{{ ai_gen_id }}">
                    <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
                      {% assign custom_image_key = 'custom_image_' | append: forloop.index %}
                      {% assign custom_image = block.settings[custom_image_key] %}
                      
                      {% if custom_image != blank %}
                        <img
                          src="{{ custom_image | image_url: width: 600 }}"
                          alt="{{ custom_image.alt | escape }}"
                          class="ai-product-card-image-{{ ai_gen_id }}"
                          loading="lazy"
                          width="600"
                          height="600"
                        >
                      {% elsif product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 600 }}"
                          alt="{{ product.featured_image.alt | escape }}"
                          class="ai-product-card-image-{{ ai_gen_id }}"
                          loading="lazy"
                          width="600"
                          height="600"
                        >
                      {% endif %}

                      {% if product.media[1] %}
                        <img
                          src="{{ product.media[1] | image_url: width: 600 }}"
                          alt="{{ product.media[1].alt | escape }}"
                          class="ai-product-card-image-secondary-{{ ai_gen_id }}"
                          loading="lazy"
                          width="600"
                          height="600"
                        >
                      {% endif %}
                    </div>

                    <div class="ai-product-card-info-{{ ai_gen_id }}">
                      {% if block.settings.show_vendor %}
                        <div class="ai-product-card-vendor-{{ ai_gen_id }}">
                          {{ product.vendor }}
                        </div>
                      {% endif %}

                      <div class="ai-product-card-title-{{ ai_gen_id }}">
                        {{ product.title }}
                      </div>

                      {% if block.settings.show_rating %}
                        <div class="ai-product-card-rating-{{ ai_gen_id }}">
                          {% if product.metafields.reviews.rating.value != blank %}
                            <span>{{ product.metafields.reviews.rating.value }} ★</span>
                          {% endif %}
                        </div>
                      {% endif %}

                      <div class="ai-product-card-price-{{ ai_gen_id }}">
                        {% if product.compare_at_price > product.price %}
                          <div class="price price--on-sale">
                            <span class="price-item price-item--sale">
                              {{ product.price | money }}
                            </span>
                            <span class="price-item price-item--regular">
                              {{ product.compare_at_price | money }}
                            </span>
                          </div>
                        {% else %}
                          <span class="price-item">
                            {{ product.price | money }}
                          </span>
                        {% endif %}
                      </div>
                    </div>
                  </a>

                  {% if block.settings.quick_add != 'none' %}
                    <div class="ai-product-quick-add-{{ ai_gen_id }}">
                      {% if block.settings.quick_add == 'standard' %}
                        <quick-add-button>
                          <form method="post" action="/cart/add">
                            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                            <button type="submit" name="add" class="quick-add-button">
                              Add to cart
                            </button>
                          </form>
                        </quick-add-button>
                      {% elsif block.settings.quick_add == 'bulk' %}
                        <quick-add-bulk>
                          <form method="post" action="/cart/add">
                            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                            <input type="number" name="quantity" value="1" min="1">
                            <button type="submit" name="add">
                              Add to cart
                            </button>
                          </form>
                        </quick-add-bulk>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  (function() {
    if (typeof Swiper !== 'undefined') {
      new Swiper('.ai-swiper-{{ ai_gen_id }}', {
        slidesPerView: {{ block.settings.products_per_row_desktop }},
        spaceBetween: 20,
        navigation: {
          nextEl: '.ai-swiper-button-next-{{ ai_gen_id }}',
          prevEl: '.ai-swiper-button-prev-{{ ai_gen_id }}',
        },
        breakpoints: {
          1024: {
            slidesPerView: {{ block.settings.products_per_row_desktop }},
            spaceBetween: 20,
          },
          768: {
            slidesPerView: {{ block.settings.products_per_row_tablet }},
            spaceBetween: 20,
          },
          320: {
            slidesPerView: {{ block.settings.products_per_row_mobile }},
            spaceBetween: 10,
          },
        },
      });
    }
  })();
</script>


              <div class="swiper-button-prev es-swiper-button">
                {%- render 'es-icon-arrow-right' -%}
              </div>
              <div class="swiper-button-next es-swiper-button">
                {%- render 'es-icon-arrow-right' -%}
              </div>
            </div>
          </div>
          <div class="esSwiper">
            <div class="swiper-wrapper">
              {% assign skip_card_product_styles = false %}
